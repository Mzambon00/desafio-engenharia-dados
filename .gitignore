# Crie o .gitignore
echo "__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
venv/
env/
.env/
.venv/
.vscode/
.idea/
*.log
.DS_Store
data/
out/
!data/.gitkeep
!out/.gitkeep" > .gitignore

# Criar pastas vazias para manter estrutura
echo "# Mantém a estrutura da pasta data" > data/.gitkeep
echo "# Mantém a estrutura da pasta out" > out/.gitkeep